{
  "server_url": "http://127.0.0.1:3737",
  "room_id": "replace_with_room_id",
  "token": "replace_with_owner_or_member_token",
  "agent": {
    "name": "Echo CLI Agent",
    "command": "node",
    "args": ["-e", "process.stdin.on('data', d => process.stdout.write('agent:' + d.toString()))"],
    "working_dir": ".",
    "capabilities": ["shell.oneshot"]
  }
}

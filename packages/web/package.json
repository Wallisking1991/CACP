{
  "name": "@cacp/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm --filter @cacp/protocol build && vite build",
    "dev": "corepack pnpm --filter @cacp/protocol build && vite --host 127.0.0.1 --port 5173",
    "test": "corepack pnpm --filter @cacp/protocol build && vitest run"
  },
  "dependencies": {
    "@cacp/protocol": "workspace:*",
    "gsap": "^3.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

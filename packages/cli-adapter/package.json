{
  "name": "@cacp/cli-adapter",
  "version": "0.1.0",
  "type": "module",
  "bin": { "cacp-cli-adapter": "./dist/index.js" },
  "scripts": {
    "build": "corepack pnpm --filter @cacp/protocol build && tsc -p tsconfig.json",
    "bundle:connector": "corepack pnpm exec esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/connector/index.cjs",
    "dev": "corepack pnpm --filter @cacp/protocol build && tsx src/index.ts",
    "test": "corepack pnpm --filter @cacp/protocol build && vitest run"
  },
  "dependencies": {
    "@cacp/protocol": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
